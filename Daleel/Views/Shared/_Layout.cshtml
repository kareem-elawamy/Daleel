@using System.Globalization
@{
    var isRtl = CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var langCode = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    var dir = isRtl ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@langCode" dir="@dir" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Daleel</title>
    <script type="importmap"></script>

    <!-- Preconnect for faster external resource loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.tailwindcss.com" />

    <!-- Theme & Tailwind setup -->
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "selector",
            theme: {
                extend: {
                    "colors": {
                        "surface-container-high": "#e6e8ea",
                        "tertiary-fixed": "#ffdad3",
                        "primary-fixed-dim": "#77d1ff",
                        "error-container": "#ffdad6",
                        "on-primary-fixed": "#001e2c",
                        "surface-container-low": "#f2f4f6",
                        "on-tertiary-fixed": "#3f0400",
                        "on-surface": "#191c1e",
                        "error": "#ba1a1a",
                        "surface-tint": "#006689",
                        "on-tertiary-container": "#790e00",
                        "on-secondary-fixed-variant": "#31447a",
                        "on-tertiary-fixed-variant": "#8e1300",
                        "surface-variant": "#e0e3e5",
                        "primary-fixed": "#c2e8ff",
                        "inverse-on-surface": "#eff1f3",
                        "surface-container-lowest": "#ffffff",
                        "tertiary": "#ba1c00",
                        "on-error-container": "#93000a",
                        "on-secondary-container": "#3a4c83",
                        "surface-bright": "#f7f9fb",
                        "tertiary-fixed-dim": "#ffb4a5",
                        "on-primary": "#ffffff",
                        "on-secondary-fixed": "#00174b",
                        "on-background": "#191c1e",
                        "surface": "#f7f9fb",
                        "secondary": "#4a5c94",
                        "on-secondary": "#ffffff",
                        "surface-container": "#eceef0",
                        "secondary-fixed": "#dbe1ff",
                        "secondary-container": "#acbffd",
                        "on-primary-container": "#004058",
                        "outline-variant": "#bdc8d0",
                        "on-surface-variant": "#3d484f",
                        "inverse-surface": "#2d3133",
                        "primary": "#006689",
                        "surface-dim": "#d8dadc",
                        "on-tertiary": "#ffffff",
                        "background": "#f7f9fb",
                        "surface-container-highest": "#e0e3e5",
                        "tertiary-container": "#ff8168",
                        "secondary-fixed-dim": "#b4c5ff",
                        "on-primary-fixed-variant": "#004d68",
                        "outline": "#6d7980",
                        "primary-container": "#00b2ec",
                        "inverse-primary": "#77d1ff",
                        "on-error": "#ffffff",
                        "daleel-navy": "#1D3166",
                        "brand-navy": "#1D3166",
                        "daleel-sky": "#00B2EC",
                        "daleel-green": "#10B981",
                        "daleel-orange": "#F9A01B",
                        "daleel-offwhite": "#F8F9FA",
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1rem",
                        "3xl": "1.5rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "gutter": "24px",
                        "section-gap": "80px",
                        "container-max": "1440px",
                        "margin-page": "48px",
                        "unit": "8px",
                        "element-gap": "16px"
                    },
                    "fontFamily": {
                        "poppins": ["Poppins", "sans-serif"],
                        "inter": ["Inter", "sans-serif"],
                        "body-lg": ["Inter"],
                        "label-sm": ["Inter"],
                        "body-md": ["Inter"],
                        "h3": ["Poppins"],
                        "h1": ["Poppins"],
                        "h2": ["Poppins"],
                        "button": ["Inter"]
                    },
                    "fontSize": {
                        "body-lg": ["18px", { "lineHeight": "1.6", "letterSpacing": "0", "fontWeight": "400" }],
                        "label-sm": ["14px", { "lineHeight": "1", "letterSpacing": "0.02em", "fontWeight": "500" }],
                        "body-md": ["16px", { "lineHeight": "1.6", "letterSpacing": "0", "fontWeight": "400" }],
                        "h3": ["24px", { "lineHeight": "1.4", "letterSpacing": "0", "fontWeight": "500" }],
                        "h1": ["48px", { "lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "600" }],
                        "h2": ["32px", { "lineHeight": "1.3", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "button": ["16px", { "lineHeight": "1", "letterSpacing": "0.01em", "fontWeight": "600" }]
                    },
                    "animation": {
                        "pulse-slow": "pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite",
                        "float": "float 6s ease-in-out infinite",
                    },
                    "keyframes": {
                        "float": {
                            "0%, 100%": { transform: "translateY(0px)" },
                            "50%": { transform: "translateY(-10px)" },
                        }
                    }
                }
            }
        };
    </script>

    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700;800&family=Cairo:wght@400;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Daleel.styles.css" asp-append-version="true" />
</head>
<body class="bg-white dark:bg-[#0A192F] font-body-md text-slate-900 dark:text-white transition-colors duration-300">
    <header
        class="bg-white/80 dark:bg-[#0A192F]/80 backdrop-blur-md border-b border-slate-200/50 dark:border-white/10 fixed w-full top-0 z-50 shadow-[0px_10px_30px_rgba(29,49,102,0.08)] dark:shadow-[0px_10px_30px_rgba(0,0,0,0.4)] transition-all duration-300"
        id="main-header">
        <div class="max-w-[1440px] mx-auto px-6 sm:px-8 h-20 flex items-center justify-between">
            <a asp-controller="Home" asp-action="Index" class="shrink-0">
                <img src="~/assets/Logo/Daleel.png" id="header-logo"
                    width="180" height="54"
                    class="h-9 sm:h-[54px] w-auto transition-all duration-300 brightness-100 invert-0 dark:brightness-0 dark:invert"
                    alt="Daleel Global Vision" />
            </a>
            <!-- Desktop Nav -->
            @{
                var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                string GetNavClass(string action) => currentAction == action 
                    ? "text-[#00B2EC] dark:text-[#F9A01B] py-1 border-b-2 border-[#00B2EC] dark:border-[#F9A01B] font-bold transition-colors" 
                    : "text-slate-900 dark:text-white hover:text-[#00B2EC] dark:hover:text-[#F9A01B] transition-colors py-1 border-b-2 border-transparent hover:border-[#00B2EC] dark:hover:border-[#F9A01B]";
                    
                string GetMobileNavClass(string action) => currentAction == action
                    ? "text-[#00B2EC] dark:text-[#F9A01B] bg-slate-50 dark:bg-slate-800/50 font-bold px-4 py-3 rounded-lg transition-colors"
                    : "text-brand-navy dark:text-white hover:text-[#00B2EC] dark:hover:text-[#F9A01B] hover:bg-slate-50 dark:hover:bg-slate-800/50 px-4 py-3 rounded-lg transition-colors";
            }
            <nav class="hidden lg:flex items-center gap-6 font-['Inter'] font-medium text-[13px] tracking-tight">
                <a class="@GetNavClass("Index")" asp-controller="Home" asp-action="Index">@SharedLocalizer["Home"]</a>
                <a class="@GetNavClass("Platforms")" id="platform" asp-controller="Home" asp-action="Platforms">@SharedLocalizer["Platforms"]</a>
                <a class="@GetNavClass("Shop")" asp-controller="Home" asp-action="Shop">@SharedLocalizer["Shop"]</a>
                <a class="@GetNavClass("Trust")" asp-controller="Home" asp-action="Trust">@SharedLocalizer["TrustGovernance"]</a>
                <a class="@GetNavClass("Partners")" asp-controller="Home" asp-action="Partners">@SharedLocalizer["Partners"]</a>
                <a class="@GetNavClass("About")" asp-controller="Home" asp-action="About">@SharedLocalizer["AboutUs"]</a>
                <a class="@GetNavClass("Contact")" asp-controller="Home" asp-action="Contact">@SharedLocalizer["ContactUs"]</a>
            </nav>

            <!-- Right Actions -->
            <div class="flex items-center gap-3">
                <!-- Theme Toggle -->
                <button id="theme-toggle" onclick="toggleTheme()"
                    class="text-slate-500 dark:text-slate-400 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] p-1.5 rounded-lg border border-slate-200 dark:border-slate-700 transition-all hover:border-[#00B2EC] dark:hover:border-[#00B2EC] flex items-center justify-center">
                    <span id="theme-icon" class="material-symbols-outlined text-[20px]">dark_mode</span>
                </button>

                <!-- RTL/LTR Toggle -->
                @{
                    var switchCulture = isRtl ? "en" : "ar";
                    var switchLanguageText = isRtl ? "English" : "عربي";
                }
                <a href="#" onclick="switchLanguage('@switchCulture'); return false;"
                    class="text-slate-500 dark:text-slate-400 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 text-xs font-semibold tracking-wide transition-all hover:border-[#00B2EC] dark:hover:border-[#00B2EC]">
                    @switchLanguageText
                </a>

                <!-- CTA -->
               <a asp-controller="Home" asp-action="Index" asp-fragment="vision" 
   class="hidden sm:block bg-[#00B2EC] text-white px-5 py-2.5 rounded-lg font-['Inter'] font-semibold text-sm shadow-sm active:scale-95 duration-150 transition-all hover:shadow-lg hover:shadow-[#00B2EC]/20 text-center">
    @SharedLocalizer["GetStarted"]
</a>
                <!-- Mobile Menu Toggle -->
                <button id="mobile-menu-btn" onclick="document.getElementById('mobile-nav').classList.toggle('hidden')"
                    class="lg:hidden p-2 text-brand-navy dark:text-white hover:text-[#00B2EC] dark:hover:text-[#00B2EC] transition-colors">
                    <span class="material-symbols-outlined text-[28px]">menu</span>
                </button>
            </div>
        </div>

        <!-- Mobile Nav Dropdown -->
        <div id="mobile-nav"
            class="hidden lg:hidden bg-white dark:bg-[#0A192F] border-t border-slate-100 dark:border-slate-800 shadow-lg">
            <nav class="max-w-[1440px] mx-auto px-6 py-4 flex flex-col gap-1 font-['Inter'] font-medium text-sm">
                <a class="@GetMobileNavClass("Index")" asp-controller="Home" asp-action="Index">@SharedLocalizer["Home"]</a>
                <a class="@GetMobileNavClass("Platforms")" asp-controller="Home" asp-action="Platforms">@SharedLocalizer["Platforms"]</a>
                <a class="@GetMobileNavClass("Shop")" asp-controller="Home" asp-action="Shop">@SharedLocalizer["Shop"]</a>
                <a class="@GetMobileNavClass("Trust")" asp-controller="Home" asp-action="Trust">@SharedLocalizer["TrustGovernance"]</a>
                <a class="@GetMobileNavClass("Partners")" asp-controller="Home" asp-action="Partners">@SharedLocalizer["Partners"]</a>
                <a class="@GetMobileNavClass("About")" asp-controller="Home" asp-action="About">@SharedLocalizer["AboutUs"]</a>
                <a class="@GetMobileNavClass("Contact")" asp-controller="Home" asp-action="Contact">@SharedLocalizer["ContactUs"]</a>
            </nav>
        </div>
    </header>
    <main role="main" class="pb-3 w-full">
        @RenderBody()
    </main>

    <footer class="relative bg-white dark:bg-[#0A192F] overflow-hidden transition-colors duration-300">
        <div class="w-full h-px bg-gradient-to-r from-transparent via-[#00B2EC]/30 to-transparent"></div>

        <div class="max-w-[1440px] mx-auto px-6 sm:px-8 pt-16 sm:pt-20 pb-8">
            <div class="grid grid-cols-2 md:grid-cols-12 gap-10 sm:gap-12 mb-16 text-start">
                <div class="col-span-2 md:col-span-4" data-animate="fade-up" data-delay="1">
                    <div class="font-['Poppins'] text-xl font-bold text-brand-navy dark:text-white mb-4">
                        <img src="~/assets/Logo/Daleel.png"
                            width="150" height="45"
                            class="w-[150px] h-auto transition-all duration-300 dark:brightness-0 dark:invert"
                            alt="Daleel Global Vision">
                    </div>
                    <p class="font-['Inter'] text-sm leading-relaxed text-brand-navy/60 dark:text-white/60 max-w-xs mb-8">
                        @SharedLocalizer["FooterDescription"]
                    </p>
                    <div class="flex gap-3">
                        <div class="relative group inline-flex items-center">
    <div class="relative z-30 w-10 h-10 rounded-xl bg-brand-navy/5 dark:bg-white/5 border border-brand-navy/10 dark:border-white/10 flex items-center justify-center text-brand-navy/60 dark:text-white/60 group-hover:text-white group-hover:bg-[#00B2EC] group-hover:border-[#00B2EC] transition-all duration-500 cursor-pointer shadow-sm">
        <span class="material-symbols-outlined text-[20px] group-hover:rotate-12 transition-transform">share</span>
    </div>

    <div class="absolute ltr:left-0 rtl:right-0 z-20 flex items-center bg-white dark:bg-[#0A192F] border border-slate-200 dark:border-slate-800 rounded-xl px-2 h-10 w-10 group-hover:w-48 opacity-0 group-hover:opacity-100 group-hover:ltr:translate-x-12 group-hover:rtl:-translate-x-12 transition-all duration-500 ease-out overflow-hidden shadow-xl">
        <div class="flex items-center gap-4 ps-2">
            <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#1877F2] transition-all hover:scale-110" title="Facebook">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">groups</span>
            </a>
            <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#E4405F] transition-all hover:scale-110" title="Instagram">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">photo_camera</span>
            </a>
            <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#0A66C2] transition-all hover:scale-110" title="LinkedIn">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">work</span>
            </a>
            <a href="https://x.com" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-black dark:hover:text-white transition-all hover:scale-110" title="X (Twitter)">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">tag</span>
            </a>
        </div>
    </div>
</div>
                        <a asp-controller="Home" asp-action="Contact"
                            class="w-10 h-10 rounded-xl bg-brand-navy/5 dark:bg-white/5 border border-brand-navy/10 dark:border-white/10 flex items-center justify-center text-brand-navy/60 dark:text-white/60 hover:text-[#00B2EC] hover:border-[#00B2EC]/30 hover:bg-[#00B2EC]/5 dark:hover:text-[#00B2EC] transition-all duration-300">
                            <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">mail</span>
                        </a>
                        <a asp-controller="Home" asp-action="Contact"
                            class="w-10 h-10 rounded-xl bg-brand-navy/5 dark:bg-white/5 border border-brand-navy/10 dark:border-white/10 flex items-center justify-center text-brand-navy/60 dark:text-white/60 hover:text-[#00B2EC] hover:border-[#00B2EC]/30 hover:bg-[#00B2EC]/5 dark:hover:text-[#00B2EC] transition-all duration-300">
                            <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">call</span>
                        </a>
                    </div>
                </div>

                <div class="md:col-span-2" data-animate="fade-up" data-delay="2">
                    <h4
                        class="font-['Inter'] text-xs font-semibold text-brand-navy/70 dark:text-white/80 uppercase tracking-widest mb-6">
                        @SharedLocalizer["Platform"]</h4>
                    <ul class="space-y-3 font-['Inter'] text-sm">
                        <li><a asp-controller="Home" asp-action="Soon"
                                class="text-brand-navy/60 dark:text-white/50 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] transition-colors duration-200">@SharedLocalizer["Solutions"]</a>
                        </li>
                        <li><a asp-controller="Home" asp-action="Soon"
                                class="text-brand-navy/60 dark:text-white/50 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] transition-colors duration-200">@SharedLocalizer["IntelligenceFeed"]</a></li>
                        <li><a asp-controller="Home" asp-action="Soon"
                                class="text-brand-navy/60 dark:text-white/50 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] transition-colors duration-200">@SharedLocalizer["RiskDashboard"]</a></li>
                        <li><a asp-controller="Home" asp-action="Soon"
                                class="text-brand-navy/60 dark:text-white/50 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] transition-colors duration-200">@SharedLocalizer["APIAccess"]</a></li>
                        <li><a asp-controller="Home" asp-action="Soon"
                                class="text-brand-navy/60 dark:text-white/50 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] transition-colors duration-200">@SharedLocalizer["Integrations"]</a>
                        </li>
                    </ul>
                </div>

                <div class="md:col-span-2" data-animate="fade-up" data-delay="3">
                    <h4
                        class="font-['Inter'] text-xs font-semibold text-brand-navy/70 dark:text-white/80 uppercase tracking-widest mb-6">
                        @SharedLocalizer["Company"]</h4>
                    <ul class="space-y-3 font-['Inter'] text-sm">
                        <li><a asp-controller="Home" asp-action="About"
                                class="text-brand-navy/60 dark:text-white/50 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] transition-colors duration-200">@SharedLocalizer["AboutUs"]</a></li>
                        <li><a asp-controller="Home" asp-action="Trust"
                                class="text-brand-navy/60 dark:text-white/50 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] transition-colors duration-200">@SharedLocalizer["TrustGovernance"]</a>
                        </li>
                        <li><a asp-controller="Home" asp-action="Partners"
                                class="text-brand-navy/60 dark:text-white/50 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] transition-colors duration-200">@SharedLocalizer["Partners"]</a>
                        </li>
                        <li><a asp-controller="Home" asp-action="Contact"
                                class="text-brand-navy/60 dark:text-white/50 hover:text-[#00B2EC] dark:hover:text-[#00B2EC] transition-colors duration-200">@SharedLocalizer["ContactUs"]</a>
                        </li>
                    </ul>
                </div>

                <div class="col-span-2 md:col-span-4" data-animate="fade-up" data-delay="4">
                    <h4
                        class="font-['Inter'] text-xs font-semibold text-brand-navy/70 dark:text-white/80 uppercase tracking-widest mb-6">
                        @SharedLocalizer["StayInformed"]</h4>
                    <p class="font-['Inter'] text-sm text-brand-navy/60 dark:text-white/60 mb-4">@SharedLocalizer["StayInformedDescription"]</p>
                    <div class="flex gap-2">
                        <input type="email" placeholder="@SharedLocalizer["EnterYourEmail"]"
                            class="flex-1 bg-brand-navy/5 dark:bg-white/5 border border-brand-navy/10 dark:border-white/10 rounded-xl px-4 py-3 text-sm text-brand-navy dark:text-white placeholder:text-brand-navy/50 dark:placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-[#00B2EC]/40 focus:border-[#00B2EC]/40 font-['Inter'] transition-all" />
                        <button
                            class="bg-[#00B2EC] text-white px-5 py-3 rounded-xl font-['Inter'] font-semibold text-sm hover:shadow-lg hover:shadow-[#00B2EC]/20 active:scale-95 transition-all duration-200 shrink-0">
                            @SharedLocalizer["Subscribe"]
                        </button>
                    </div>
                    <p class="font-['Inter'] text-[11px] text-brand-navy/40 dark:text-white/30 mt-3">@SharedLocalizer["NoSpam"]</p>
                </div>

            </div>

            <div class="w-full h-px bg-brand-navy/5 dark:bg-white/10 mb-8"></div>

            <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
                <p class="font-['Inter'] text-xs text-brand-navy/50 dark:text-white/40">
                    &copy; @DateTime.Now.Year Daleel Global Vision. @SharedLocalizer["AllRightsReserved"]
                </p>
                
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function switchLanguage(culture) {
            sessionStorage.setItem('langSwitchScrollPosition', window.scrollY);
            var returnUrl = window.location.pathname + window.location.search + window.location.hash;
            var url = '@Url.Action("SetLanguage", "Language")' + '?culture=' + culture + '&returnUrl=' + encodeURIComponent(returnUrl);
            window.location.href = url;
        }

        window.addEventListener('load', function() {
            var scrollPosition = sessionStorage.getItem('langSwitchScrollPosition');
            if (scrollPosition !== null) {
                // Disable smooth scrolling temporarily to jump instantly to the saved position
                document.documentElement.style.scrollBehavior = 'auto';
                window.scrollTo(0, parseInt(scrollPosition, 10));
                
                // Restore smooth scrolling if defined in CSS class
                setTimeout(function() {
                    document.documentElement.style.scrollBehavior = '';
                }, 50);
                
                sessionStorage.removeItem('langSwitchScrollPosition');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
