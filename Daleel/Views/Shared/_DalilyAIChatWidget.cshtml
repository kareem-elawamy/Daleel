<div id="dalily-ai-chat-widget" class="fixed bottom-6 right-6 z-[100] flex flex-col items-end transition-all duration-300">
    <!-- Chat Window -->
    <div id="dalily-ai-chat-window" class="hidden flex flex-col w-[350px] sm:w-[400px] h-[600px] max-h-[80vh] bg-white dark:bg-[#0A192F] rounded-2xl shadow-[0px_10px_40px_rgba(29,49,102,0.15)] dark:shadow-[0px_10px_40px_rgba(0,0,0,0.5)] border border-slate-200 dark:border-white/10 overflow-hidden transition-all duration-300 mb-4 origin-bottom-right scale-95 opacity-0">
        
        <!-- Header -->
        <div class="bg-brand-navy dark:bg-slate-800 text-white px-5 py-4 flex items-center justify-between shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-[#00B2EC] flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-white text-[20px]">smart_toy</span>
                </div>
                <div>
                    <h3 class="font-['Poppins'] font-semibold text-sm leading-tight">Dalily AI Assistant</h3>
                    <p class="font-['Inter'] text-[11px] text-white/70 flex items-center gap-1">
                        <span class="w-1.5 h-1.5 rounded-full bg-[#10B981] animate-pulse"></span> Online
                    </p>
                </div>
            </div>
            <button id="dalily-ai-close-btn" class="text-white/70 hover:text-white hover:bg-white/10 p-1.5 rounded-lg transition-colors">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>

        <!-- Message Area -->
        <div id="dalily-ai-messages" class="flex-1 overflow-y-auto p-4 space-y-4 font-['Inter'] text-sm bg-slate-50 dark:bg-[#0A192F]/50 scroll-smooth">
            <!-- Welcome Message -->
            <div class="flex gap-3">
                <div class="w-8 h-8 rounded-full bg-brand-navy/10 dark:bg-white/10 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-brand-navy dark:text-white text-[16px]">smart_toy</span>
                </div>
                <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-white/5 p-3 rounded-2xl rounded-tl-sm text-slate-800 dark:text-slate-200 shadow-sm">
                    Hello! I'm Dalily's AI Assistant. How can I help you today? You can text or use voice.
                </div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-4 bg-white dark:bg-[#0A192F] border-t border-slate-200 dark:border-white/10 shrink-0">
            <div class="flex items-end gap-2 relative">
                <!-- Text Input -->
                <div class="flex-1 relative">
                    <textarea id="dalily-ai-input" rows="1" placeholder="Type your message..." class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl pl-4 pr-10 py-3 text-sm text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-[#00B2EC]/40 focus:border-[#00B2EC]/40 resize-none max-h-[120px] scrollbar-thin"></textarea>
                </div>

                <!-- Send Button -->
                <button id="dalily-ai-send-btn" class="w-11 h-11 rounded-xl bg-brand-navy/5 dark:bg-white/5 text-brand-navy dark:text-white hover:bg-brand-navy/10 dark:hover:bg-white/10 flex items-center justify-center transition-colors shrink-0 disabled:opacity-50 disabled:cursor-not-allowed">
                    <span class="material-symbols-outlined text-[20px] ltr:ml-1 rtl:mr-1">send</span>
                </button>

                <!-- Microphone Button -->
                <button id="dalily-ai-mic-btn" class="w-11 h-11 rounded-xl bg-[#00B2EC] hover:bg-[#00B2EC]/90 text-white flex items-center justify-center transition-all shadow-md hover:shadow-lg hover:shadow-[#00B2EC]/20 shrink-0 relative group">
                    <span class="material-symbols-outlined text-[24px]">mic</span>
                    <!-- Recording indicator (hidden by default) -->
                    <span id="dalily-ai-mic-pulse" class="hidden absolute -inset-1 rounded-xl border-2 border-[#00B2EC] animate-ping opacity-75"></span>
                </button>
            </div>
            <div class="text-center mt-2">
                <span class="text-[10px] text-slate-400 font-['Inter']">Powered by Gemini Multimodal Live</span>
            </div>
        </div>
    </div>

    <!-- Toggle Button -->
    <button id="dalily-ai-toggle-btn" class="w-14 h-14 rounded-full bg-brand-navy dark:bg-slate-800 text-white flex items-center justify-center shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 relative group">
        <span class="material-symbols-outlined text-[28px] group-hover:scale-110 transition-transform">forum</span>
        <!-- Notification Badge -->
        <span class="absolute top-0 right-0 w-3.5 h-3.5 bg-[#F9A01B] border-2 border-white dark:border-slate-800 rounded-full"></span>
    </button>
</div>
