@{
    ViewData["Title"] = "Trust & Governance";
}

<section class="relative py-32 overflow-hidden transition-colors duration-300">
    <!-- Ambient Background Glows -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute top-1/4 ltr:-right-40 rtl:-left-40 w-[600px] h-[600px] rounded-full bg-[#00B2EC]/10 blur-[120px]"></div>
        <div class="absolute bottom-0 ltr:-left-20 rtl:-right-20 w-[500px] h-[500px] rounded-full bg-[#F9A01B]/5 blur-[100px]"></div>
    </div>

    <div class="relative z-10 max-w-[1440px] mx-auto px-6 sm:px-8">

        <!-- Page Header -->
        <div class="text-center max-w-3xl mx-auto mb-20" data-animate="fade-up">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-navy/5 dark:bg-white/5 text-slate-900 dark:text-slate-300 font-['Inter'] text-xs font-semibold tracking-wide mb-6">
                <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">shield_lock</span>
                Security First
            </div>
            <h1 class="font-['Poppins'] text-4xl sm:text-5xl md:text-6xl font-bold text-slate-900 dark:text-white leading-tight mb-6">
                Trust & <span class="text-gradient">Governance</span>
            </h1>
            <p class="font-['Inter'] text-lg sm:text-xl text-slate-600 dark:text-slate-400 leading-relaxed">
                Your intelligence remains strictly yours. We built Daleel from the ground up to exceed global compliance and data sovereignty requirements.
            </p>
        </div>

        <!-- Core Pillars Grid -->
        <div class="grid md:grid-cols-3 gap-8 mb-24">

            <div class="glass-card rounded-2xl p-8 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(0,178,236,0.1)] transition-all duration-500" data-animate="fade-up" data-delay="1">
                <div class="w-14 h-14 rounded-xl bg-[#00B2EC]/10 flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-[#00B2EC] text-[28px]" style="font-variation-settings: 'FILL' 1;">verified_user</span>
                </div>
                <h3 class="font-['Poppins'] text-xl font-bold text-slate-900 dark:text-white mb-3">Military-Grade Encryption</h3>
                <p class="font-['Inter'] text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                    End-to-end 256-bit AES encryption ensures your queries, saved searches, and collaborative projects are secure in transit and at rest.
                </p>
            </div>

            <div class="glass-card rounded-2xl p-8 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(249,160,27,0.1)] transition-all duration-500" data-animate="fade-up" data-delay="2">
                <div class="w-14 h-14 rounded-xl bg-[#F9A01B]/10 flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-[#F9A01B] text-[28px]" style="font-variation-settings: 'FILL' 1;">policy</span>
                </div>
                <h3 class="font-['Poppins'] text-xl font-bold text-slate-900 dark:text-white mb-3">Global Compliance</h3>
                <p class="font-['Inter'] text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                    Fully compliant with GDPR, CCPA, and regional data localization mandates. We don't share, sell, or exploit your strategic behavior.
                </p>
            </div>

            <div class="glass-card rounded-2xl p-8 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(239,65,35,0.1)] transition-all duration-500" data-animate="fade-up" data-delay="3">
                <div class="w-14 h-14 rounded-xl bg-[#EF4123]/10 flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-[#EF4123] text-[28px]" style="font-variation-settings: 'FILL' 1;">account_tree</span>
                </div>
                <h3 class="font-['Poppins'] text-xl font-bold text-slate-900 dark:text-white mb-3">Ethical AI Framework</h3>
                <p class="font-['Inter'] text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                    Our models are audited for bias and hallucination mitigation. Intelligence is transparently sourced and clearly cited.
                </p>
            </div>
        </div>

        <!-- Stats row -->
        <div class="glass-card rounded-2xl p-8 md:p-12 grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-animate="scale-in" data-delay="4">
            <div>
                <p class="font-['Poppins'] text-4xl font-bold text-[#00B2EC] mb-2">256-bit</p>
                <p class="font-['Inter'] text-sm text-slate-500 dark:text-slate-400 uppercase tracking-wider">AES Encryption</p>
            </div>
            <div>
                <p class="font-['Poppins'] text-4xl font-bold text-[#F9A01B] mb-2">GDPR</p>
                <p class="font-['Inter'] text-sm text-slate-500 dark:text-slate-400 uppercase tracking-wider">Compliant</p>
            </div>
            <div>
                <p class="font-['Poppins'] text-4xl font-bold text-[#EF4123] mb-2">SOC 2</p>
                <p class="font-['Inter'] text-sm text-slate-500 dark:text-slate-400 uppercase tracking-wider">Type II Certified</p>
            </div>
            <div>
                <p class="font-['Poppins'] text-4xl font-bold text-slate-900 dark:text-white mb-2">99.99%</p>
                <p class="font-['Inter'] text-sm text-slate-500 dark:text-slate-400 uppercase tracking-wider">Uptime SLA</p>
            </div>
        </div>

    </div>
</section>
