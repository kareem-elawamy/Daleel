@{
    ViewData["Title"] = "Home Page";
}

@functions {
    public string ToLocalNumerals(string input)
    {
        if (System.Threading.Thread.CurrentThread.CurrentCulture.Name.StartsWith("ar"))
        {
            string replaced = input.Replace("M", " مليون")
                                   .Replace("K", " ألف")
                                   .Replace("min", " دقائق")
                                   .Replace("-in-", " في ")
                                   .Replace('0', '٠')
                                   .Replace('1', '١')
                                   .Replace('2', '٢')
                                   .Replace('3', '٣')
                                   .Replace('4', '٤')
                                   .Replace('5', '٥')
                                   .Replace('6', '٦')
                                   .Replace('7', '٧')
                                   .Replace('8', '٨')
                                   .Replace('9', '٩');
                                   
            if (replaced.EndsWith("+"))
            {
                replaced = "+" + replaced.TrimEnd('+');
            }
            
            return replaced;
        }
        return input;
    }
}

<section id="main-scrolly" class="relative bg-slate-50 dark:bg-[#0B1220] transition-colors duration-300 min-h-screen overflow-hidden group">

    <div class="relative min-h-screen w-full flex items-center justify-center overflow-hidden py-24">

        <!-- Three.js 3D Particle Background -->
        <canvas id="scrolly-canvas" class="absolute inset-0 w-full h-full z-0"></canvas>

        <!-- Ambient Glows -->
        <div class="absolute inset-0 pointer-events-none z-[1]">
            <div id="glow-1"
                class="absolute -top-1/4 -right-1/4 w-[800px] h-[800px] bg-[#00B2EC]/20 rounded-full blur-[120px] transition-all duration-700">
            </div>
            <div id="glow-2"
                class="absolute -bottom-1/4 -left-1/4 w-[600px] h-[600px] bg-[#10B981]/12 rounded-full blur-[100px] transition-all duration-700">
            </div>
        </div>

        <!-- Step Progress Indicator (Left Side) -->
        <div class="hidden sm:flex absolute start-8 top-1/2 -translate-y-1/2 flex-col gap-3 z-50">
            <div class="step-dot cursor-pointer w-2 h-8 bg-brand-navy/10 dark:bg-white/10 rounded-full overflow-hidden transition-all hover:bg-brand-navy/30 dark:hover:bg-white/30" data-slide="0">
                <div class="step-fill w-full h-0 bg-[#00B2EC] transition-all duration-500"></div>
            </div>
            <div class="step-dot cursor-pointer w-2 h-8 bg-brand-navy/10 dark:bg-white/10 rounded-full overflow-hidden transition-all hover:bg-brand-navy/30 dark:hover:bg-white/30" data-slide="1">
                <div class="step-fill w-full h-0 bg-[#00B2EC] transition-all duration-500"></div>
            </div>
            <div class="step-dot cursor-pointer w-2 h-8 bg-brand-navy/10 dark:bg-white/10 rounded-full overflow-hidden transition-all hover:bg-brand-navy/30 dark:hover:bg-white/30" data-slide="2">
                <div class="step-fill w-full h-0 bg-[#10B981] transition-all duration-500"></div>
            </div>
            <div class="step-dot cursor-pointer w-2 h-8 bg-brand-navy/10 dark:bg-white/10 rounded-full overflow-hidden transition-all hover:bg-brand-navy/30 dark:hover:bg-white/30" data-slide="3">
                <div class="step-fill w-full h-0 bg-[#F9A01B] transition-all duration-500"></div>
            </div>
            <div class="step-dot cursor-pointer w-2 h-8 bg-brand-navy/10 dark:bg-white/10 rounded-full overflow-hidden transition-all hover:bg-brand-navy/30 dark:hover:bg-white/30" data-slide="4">
                <div class="step-fill w-full h-0 bg-[#00B2EC] transition-all duration-500"></div>
            </div>
        </div>

        <!-- Slider Controls (Right Side / Arrows) -->
        <div class="flex absolute end-4 sm:end-8 top-1/2 -translate-y-1/2 z-50 flex-col gap-2 sm:gap-4 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity duration-300">
            <button id="slider-prev" class="p-2 rounded-full bg-brand-navy/5 dark:bg-white/5 backdrop-blur-md border border-brand-navy/10 dark:border-white/10 text-brand-navy dark:text-white hover:bg-[#00B2EC] hover:text-white transition-all shadow-lg focus:outline-none">
                <span class="material-symbols-outlined text-lg">keyboard_arrow_up</span>
            </button>
            <button id="slider-next" class="p-2 rounded-full bg-brand-navy/5 dark:bg-white/5 backdrop-blur-md border border-brand-navy/10 dark:border-white/10 text-brand-navy dark:text-white hover:bg-[#00B2EC] hover:text-white transition-all shadow-lg focus:outline-none">
                <span class="material-symbols-outlined text-lg">keyboard_arrow_down</span>
            </button>
        </div>

        <!-- Content Layer -->
        <div class="relative w-full max-w-6xl px-4 sm:px-8 z-10 h-[500px] flex items-center">

            <!-- ═══ Slide 0: Welcome ═══ -->
            <div class="story-slide opacity-0 absolute inset-0 flex flex-col items-center text-center justify-center translate-y-10 transition-all duration-700"
