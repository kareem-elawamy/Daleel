                <span class="text-[#00B2EC]  font-bold tracking-[0.2em] rtl:tracking-normal text-xs uppercase mb-4">@SharedLocalizer["WelcomeToDaleel"]</span>
                <h1
                    class="font-['Poppins'] text-3xl sm:text-5xl md:text-7xl text-brand-navy dark:text-white font-extrabold leading-tight">
                    @SharedLocalizer["GlobalVision"]<br /><span class="text-gradient dark:text-white/70">@SharedLocalizer["LocalPrecision"]</span>
                </h1>
                <p
                    class="mt-4 sm:mt-6 text-slate-700 dark:text-white/70 text-base sm:text-lg max-w-2xl mx-auto leading-relaxed">
                    @SharedLocalizer["HeroDescription"]
                </p>
                <!-- Scroll Indicator -->
                <a href="#vision" class="mt-12 flex flex-col items-center gap-2 text-[#10B981] hover:text-[#059669] transition-colors group cursor-pointer animate-bounce">
                    <span class="text-xs uppercase tracking-widest rtl:tracking-normal font-semibold group-hover:scale-105 transition-transform">@SharedLocalizer["ScrollToExplore"]</span>
                    <span class="material-symbols-outlined group-hover:scale-110 transition-transform">expand_more</span>
                </a>
            </div>

            <!-- ═══ Slide 1: Data Harvest ═══ -->
            <div class="story-slide opacity-0 absolute inset-0 flex items-center justify-center translate-y-10 transition-all duration-700 w-full"
                data-index="1">
                <div class="grid md:grid-cols-2 gap-4 sm:gap-8 md:gap-12 items-center w-full px-2 sm:px-0">
                    <!-- Start: Content -->
                    <div class="text-start">
                        <div
                            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#00B2EC]/10 text-[#00B2EC] dark:text-white/70 text-xs font-semibold tracking-wide rtl:tracking-normal mb-4 sm:mb-6">
                            <span class="material-symbols-outlined text-[14px]"
                                style="font-variation-settings: 'FILL' 1;">sensors</span>
                            @SharedLocalizer["DataIntelligence"]
                        </div>
                        <h2
                            class="font-['Poppins'] text-xl sm:text-3xl md:text-5xl dark:text-white/70 text-brand-navy font-bold leading-tight mb-3 sm:mb-6">
                            @SharedLocalizer["TenMillionSources"]<br /><span class="text-slate-600 dark:text-white/65">@SharedLocalizer["OneTruth"]</span>
                        </h2>
                        <p
                            class="text-slate-700 dark:text-white/70 text-sm sm:text-lg leading-relaxed mb-6 sm:mb-8">
                            @SharedLocalizer["HarvestDescription"]
                        </p>
                        <div class="grid grid-cols-3 gap-4 sm:gap-6 dark:text-white/70">
                            <div>
                                <p class="text-brand-navy dark:text-white font-bold text-2xl" dir="auto">@ToLocalNumerals("140+")</p>
                                <p class="text-slate-500 dark:text-white/40 text-xs uppercase tracking-widest rtl:tracking-normal">
                                    @SharedLocalizer["Countries"]</p>
                            </div>
                            <div>
                                <p class="text-brand-navy dark:text-white font-bold text-2xl" dir="auto">@ToLocalNumerals("24/7")</p>
                                <p class="text-slate-500 dark:text-white/40 text-xs uppercase tracking-widest rtl:tracking-normal">
                                    @SharedLocalizer["Monitoring"]</p>
                            </div>
                            <div>
                                <p class="text-brand-navy dark:text-white font-bold text-2xl" dir="auto">@ToLocalNumerals("100%")</p>
                                <p class="text-slate-500 dark:text-white/40 text-xs uppercase tracking-widest rtl:tracking-normal">
                                    @SharedLocalizer["Verified"]</p>
                            </div>
                        </div>
                    </div>
                    <!-- Right: Visual -->
                    <div class="flex items-center justify-center mt-4 sm:mt-8 md:mt-0">
                        <div class="relative">
                            <img src="~/assets/images/globe_network.png" alt="Global intelligence network"
                                class="w-full max-w-[140px] sm:max-w-xs md:max-w-md rounded-2xl opacity-80 shadow-2xl shadow-[#00B2EC]/10" />
                            <div
                                class="absolute inset-0 rounded-2xl bg-gradient-to-t from-white/40 dark:from-brand-navy/40 to-transparent">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══ Slide 2: AI Engine ═══ -->
            <div class="story-slide opacity-0 absolute  inset-0 flex items-center justify-center translate-y-10 transition-all duration-700 w-full"
                data-index="2">
                <div class="grid md:grid-cols-2 gap-4 sm:gap-8 md:gap-12 items-center w-full px-2 sm:px-0">
                    <!-- Start: Visual -->
                    <div class="flex items-center justify-center order-2 md:order-none mt-4 sm:mt-8 md:mt-0">
                        <div class="relative">
                            <img src="~/assets/images/ai_neural.png" alt="AI neural fusion engine"
                                class="w-full max-w-[140px] sm:max-w-xs md:max-w-md rounded-2xl opacity-80 shadow-2xl shadow-[#10B981]/10" />
                            <div
                                class="absolute inset-0 rounded-2xl bg-gradient-to-t from-white/40 dark:from-brand-navy/40 to-transparent">
                            </div>
                        </div>
                    </div>
                    <!-- Right: Content -->
                    <div class="text-start order-1">
                        <div
                            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#10B981]/10 text-[#10B981] text-xs font-semibold tracking-wide rtl:tracking-normal mb-4 sm:mb-6">
                            <span class="material-symbols-outlined text-[14px]"
                                style="font-variation-settings: 'FILL' 1;">psychology</span>
                            @SharedLocalizer["NeuralFusionEngine"]
                        </div>
                        <h2
                            class="font-['Poppins'] text-xl sm:text-3xl md:text-5xl text-brand-navy dark:text-white font-bold leading-tight mb-3 sm:mb-6">
                            @SharedLocalizer["AIThatSees"]<br /><span class="text-gradient-red">@SharedLocalizer["WhatYouCant"]</span>
                        </h2>
                        <p
                            class="text-slate-700 dark:text-white/70 text-sm sm:text-lg leading-relaxed mb-6 sm:mb-8">
                            @SharedLocalizer["AIDescription"]
                        </p>
                        <!-- Mini progress bars -->
                        <div class="space-y-4 max-w-sm">
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-slate-600 dark:text-white/65 text-xs">@SharedLocalizer["PatternRecognition"]</span>
                                    <span class="text-[#10B981] text-xs font-bold" dir="auto">@ToLocalNumerals("94%")</span>
                                </div>
                                <div
                                    class="w-full h-1.5 rounded-full bg-brand-navy/10 dark:bg-white/10 overflow-hidden">
                                    <div
                                        class="h-full rounded-full bg-gradient-to-r from-[#10B981] to-[#F9A01B] w-[94%]">
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-slate-600 dark:text-white/65 text-xs">@SharedLocalizer["SentimentAnalysis"]</span>
                                    <span class="text-[#F9A01B] text-xs font-bold" dir="auto">@ToLocalNumerals("87%")</span>
                                </div>
                                <div
                                    class="w-full h-1.5 rounded-full bg-brand-navy/10 dark:bg-white/10 overflow-hidden">
                                    <div
                                        class="h-full rounded-full bg-gradient-to-r from-[#F9A01B] to-[#00B2EC] w-[87%]">
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-slate-600 dark:text-white/65 text-xs">@SharedLocalizer["RiskCorrelation"]</span>
                                    <span class="text-[#00B2EC] text-xs font-bold" dir="auto">@ToLocalNumerals("91%")</span>
                                </div>
                                <div
                                    class="w-full h-1.5 rounded-full bg-brand-navy/10 dark:bg-white/10 overflow-hidden">
                                    <div class="h-full rounded-full bg-[#00B2EC] w-[91%]"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══ Slide 3: Strategic Dashboard ═══ -->
            <div class="story-slide opacity-0 absolute inset-0 flex items-center justify-center translate-y-10 transition-all duration-700 w-full"
                data-index="3">
                <div class="grid md:grid-cols-2 gap-4 sm:gap-8 md:gap-12 items-center w-full px-2 sm:px-0">
                    <!-- Start: Content -->
                    <div class="text-start">
                        <div
                            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#F9A01B]/10 text-[#F9A01B] text-xs font-semibold tracking-wide rtl:tracking-normal mb-4 sm:mb-6">
                            <span class="material-symbols-outlined text-[14px]"
                                style="font-variation-settings: 'FILL' 1;">dashboard</span>
                            @SharedLocalizer["StrategicCommand"]
                        </div>
                        <h2
                            class="font-['Poppins'] text-xl sm:text-3xl md:text-5xl text-brand-navy dark:text-white font-bold leading-tight mb-3 sm:mb-6">
                            @SharedLocalizer["ClarityFrom"]<br /><span class="text-[#F9A01B]">@SharedLocalizer["Complexity"]</span>
                        </h2>
                        <p
                            class="text-slate-700 dark:text-white/70 text-sm sm:text-lg leading-relaxed mb-6 sm:mb-8">
                            @SharedLocalizer["DashboardDescription"]
                        </p>
                        <!-- Mini dashboard stats -->
                        <div class="grid grid-cols-2 gap-4 max-w-sm">
                            <div class="glass-card rounded-xl p-4 text-center">
                                <p class="font-['Poppins'] text-2xl font-bold text-emerald-400" dir="auto">▲ @ToLocalNumerals("12.4%")</p>
                                <p
                                    class="text-slate-500 dark:text-white/40 text-[10px] uppercase tracking-wider rtl:tracking-normal mt-1">
                                    @SharedLocalizer["OpportunityScore"]</p>
                            </div>
                            <div class="glass-card rounded-xl p-4 text-center">
                                <p class="font-['Poppins'] text-2xl font-bold text-[#10B981]" dir="auto">▼ @ToLocalNumerals("3.1%")</p>
                                <p
                                    class="text-slate-500 dark:text-white/40 text-[10px] uppercase tracking-wider rtl:tracking-normal mt-1">
                                    @SharedLocalizer["RiskExposure"]</p>
                            </div>
                        </div>
                    </div>
                    <!-- Right: Visual -->
                    <div class="flex items-center justify-center mt-4 sm:mt-8 md:mt-0">
                        <div class="relative">
                            <img src="~/assets/images/data_dashboard.png" alt="Strategic analytics dashboard"
                                class="w-full max-w-[160px] sm:max-w-xs md:max-w-md rounded-2xl opacity-80 shadow-2xl shadow-[#F9A01B]/10" />
                            <div
                                class="absolute inset-0 rounded-2xl bg-gradient-to-t from-white/40 dark:from-brand-navy/40 to-transparent">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══ Slide 4: CTA ═══ -->
            <div class="story-slide opacity-0 absolute inset-0 flex flex-col items-center text-center justify-center translate-y-10 transition-all duration-700 px-2 sm:px-0 w-full"
                data-index="4">
                <div
                    class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl glass-card flex items-center justify-center mb-6 sm:mb-8">
                    <span class="material-symbols-outlined text-[#00B2EC] text-3xl sm:text-4xl"
                        style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
                </div>
                <h2
                    class="font-['Poppins'] text-2xl sm:text-4xl md:text-6xl text-brand-navy dark:text-white font-bold mb-3 sm:mb-4">
                    @SharedLocalizer["ReadyToLead"]</h2>
                <p class="text-slate-700 dark:text-white/65 text-sm sm:text-lg max-w-xl mb-6 sm:mb-10 px-4">
                    @SharedLocalizer["ReadyToLeadDesc"]
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a asp-controller="Home" asp-action="Platforms"
                        class="relative group overflow-hidden bg-gradient-to-r from-[#00B2EC] to-[#008dbb] text-white px-8 py-3 rounded-2xl font-semibold transition-all hover:scale-[1.02] active:scale-95 shadow-lg shadow-blue-500/25">
                        <span class="relative z-10">@SharedLocalizer["ExploreSolutions"]</span>
                        <div
                            class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                        </div>
                    </a>

                    <a asp-controller="Home" asp-action="Contact"
                        class="backdrop-blur-md bg-brand-navy/5 dark:bg-white/5 border border-brand-navy/10 dark:border-white/10 text-brand-navy dark:text-white px-8 py-3 rounded-2xl font-semibold transition-all hover:bg-brand-navy/10 dark:hover:bg-white/10 active:scale-95 text-center">
                        @SharedLocalizer["DownloadBriefing"]
                    </a>
                </div>
            </div>

        </div><!-- /content layer -->
    </div><!-- /sticky -->
</section>

<section id="vision" class="relative bg-[#F8F9FA] dark:bg-[#060D1A] overflow-hidden py-20 sm:py-28 transition-colors duration-300">

    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div
            class="absolute -top-32 ltr:-right-32 rtl:-left-32 w-[600px] h-[600px] rounded-full bg-[#00B2EC]/5 blur-3xl">
        </div>
        <div
            class="absolute -bottom-40 ltr:-left-40 rtl:-right-40 w-[500px] h-[500px] rounded-full bg-[#F9A01B]/5 blur-3xl">
        </div>
    </div>

    <div class="relative z-10 max-w-[1440px] mx-auto px-6 sm:px-8 grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="space-y-8 text-start" data-animate="slide-start">
            <div
                class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gradient-to-r from-[#00B2EC] to-[#008dbb] text-white font-['Inter'] text-xs font-semibold tracking-wide shadow-sm">
                <span class="material-symbols-outlined text-[14px]"
                    style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                @SharedLocalizer["EnterpriseGradeIntelligence"]
            </div>

            <h1
                class="font-['Poppins'] text-[clamp(2.25rem,5vw,3.5rem)] font-extrabold leading-[1.1] tracking-tight text-brand-navy dark:text-white transition-colors duration-300">
                @SharedLocalizer["PrecisionStrategy"]<br class="hidden lg:block" /> @SharedLocalizer["ForTheGlobalMarket"]
            </h1>

            <p
                class="font-['Inter'] text-lg leading-relaxed text-slate-500 dark:text-slate-400 max-w-xl transition-colors duration-300">
                @SharedLocalizer["PrecisionStrategyDesc"]
            </p>

            <div class="flex flex-wrap gap-4 pt-2">
                <a asp-controller="Home" asp-action="Platforms"
                    class="bg-[#00B2EC] text-white px-8 py-4 rounded-xl font-['Inter'] font-semibold text-base shadow-lg shadow-[#00B2EC]/20 hover:shadow-xl hover:shadow-[#00B2EC]/30 active:scale-95 transition-all duration-300 text-center">
                    @SharedLocalizer["ExploreSolutions"]
                </a>
                <a asp-controller="Home" asp-action="Contact"
                    class="border border-brand-navy/20 dark:border-white/20 text-brand-navy dark:text-white px-8 py-4 rounded-xl font-['Inter'] font-semibold text-base hover:bg-brand-navy/5 dark:hover:bg-white/5 active:scale-95 transition-all duration-300 text-center">
                    @SharedLocalizer["WatchBriefing"]
                </a>
            </div>
        </div>

        <div class="bg-white/70 dark:bg-[#0A192F]/70 backdrop-blur-xl border border-slate-200 dark:border-slate-800 shadow-lg rounded-2xl p-0 transition-all duration-300 flex flex-col overflow-hidden"
            data-animate="slide-end" data-delay="2" style="max-height: 520px; min-height: 420px;">

            <!-- Chat Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-slate-800 shrink-0">
                <h3 class="font-['Poppins'] text-lg font-semibold text-brand-navy dark:text-white flex items-center gap-2.5">
                    <span class="material-symbols-outlined text-[#00B2EC]"
                        style="font-variation-settings: 'FILL' 1;">psychology</span>
                    @SharedLocalizer["GlobalInsightAI"]
                </h3>
                <span class="inline-flex items-center gap-2 text-xs font-['Inter'] font-medium text-slate-400">
                    <span class="relative flex h-2.5 w-2.5">
                        <span class="absolute inline-flex h-full w-full rounded-full bg-[#10B981] opacity-75 animate-ping"></span>
                        <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-[#10B981]"></span>
                    </span>
                    @SharedLocalizer["Online"]
                </span>
            </div>

            <!-- Chat Messages Area -->
            <div id="daleel-chat-messages" class="flex-1 overflow-y-auto px-5 py-4 space-y-1 scroll-smooth" style="min-height: 200px;">
                <!-- Messages injected by JS -->
            </div>

            <!-- Quick Suggestions -->
            <div id="daleel-chat-chips" class="flex flex-wrap gap-1.5 px-5 pb-2 shrink-0">
                <button type="button" class="daleel-chat-chip px-3 py-1 rounded-full text-[11px] bg-slate-100 dark:bg-[#112240] text-slate-600 dark:text-slate-300 hover:bg-[#00B2EC] hover:text-white transition-all cursor-pointer"
                    data-query="@SharedLocalizer["MarketVolatility"]">@SharedLocalizer["MarketVolatility"]</button>
                <button type="button" class="daleel-chat-chip px-3 py-1 rounded-full text-[11px] bg-slate-100 dark:bg-[#112240] text-slate-600 dark:text-slate-300 hover:bg-[#00B2EC] hover:text-white transition-all cursor-pointer"
                    data-query="@SharedLocalizer["SupplyChain"]">@SharedLocalizer["SupplyChain"]</button>
            </div>

            <!-- Chat Input -->
            <form id="daleel-chat-form" class="px-4 pb-4 shrink-0" onsubmit="return false;">
                <div class="relative flex items-center gap-2">
                    <input id="daleel-chat-input"
                        class="flex-1 bg-white dark:bg-[#112240] p-3.5 pe-14 rounded-xl border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-[#00B2EC] outline-none text-brand-navy dark:text-white text-sm font-['Inter'] placeholder:text-slate-400"
                        placeholder="@SharedLocalizer["AnalyzeTradeCorridors"]" type="text" autocomplete="off" />
                    <button id="daleel-chat-send" type="submit"
                        class="absolute end-14 top-1/2 -translate-y-1/2 p-2 bg-[#00B2EC] text-white rounded-lg hover:bg-[#00a0d6] active:scale-90 transition-all flex items-center justify-center disabled:opacity-50 disabled:cursor-not-allowed">
                        <span class="material-symbols-outlined text-[18px] inline-block rtl:rotate-180">send</span>
                    </button>
                    <!-- Voice Button -->
                    <button id="daleel-voice-btn" type="button"
                        class="absolute end-2.5 top-1/2 -translate-y-1/2 p-2 bg-[#00B2EC] text-white rounded-lg hover:bg-[#00a0d6] active:scale-90 transition-all flex items-center justify-center"
