@{
    ViewData["Title"] = "Home Page";
}

<section id="main-scrolly" class="relative bg-slate-50 dark:bg-[#0B1220] transition-colors duration-300"
    style="height: 800vh;">

    <div class="sticky top-0 h-screen w-full flex items-center justify-center overflow-hidden">

        <!-- Three.js 3D Particle Background -->
        <canvas id="scrolly-canvas" class="absolute inset-0 w-full h-full z-0"></canvas>

        <!-- Ambient Glows -->
        <div class="absolute inset-0 pointer-events-none z-[1]">
            <div id="glow-1"
                class="absolute -top-1/4 -right-1/4 w-[800px] h-[800px] bg-[#00B2EC]/20 rounded-full blur-[120px] transition-all duration-700">
            </div>
            <div id="glow-2"
                class="absolute -bottom-1/4 -left-1/4 w-[600px] h-[600px] bg-[#EF4123]/12 rounded-full blur-[100px] transition-all duration-700">
            </div>
        </div>

        <!-- Step Progress Indicator (Left Side) -->
        <div class="hidden sm:flex absolute start-8 top-1/2 -translate-y-1/2 flex-col gap-3 z-50">
            <div class="step-dot w-1 h-6 bg-brand-navy/20 dark:bg-white/30 rounded-full overflow-hidden">
                <div class="step-fill w-full h-0 bg-[#00B2EC] transition-all duration-100"></div>
            </div>
            <div class="step-dot w-1 h-6 bg-brand-navy/20 dark:bg-white/30 rounded-full overflow-hidden">
                <div class="step-fill w-full h-0 bg-[#00B2EC] transition-all duration-100"></div>
            </div>
            <div class="step-dot w-1 h-6 bg-brand-navy/20 dark:bg-white/30 rounded-full overflow-hidden">
                <div class="step-fill w-full h-0 bg-[#EF4123] transition-all duration-100"></div>
            </div>
            <div class="step-dot w-1 h-6 bg-brand-navy/20 dark:bg-white/30 rounded-full overflow-hidden">
                <div class="step-fill w-full h-0 bg-[#F9A01B] transition-all duration-100"></div>
            </div>
            <div class="step-dot w-1 h-6 bg-brand-navy/20 dark:bg-white/30 rounded-full overflow-hidden">
                <div class="step-fill w-full h-0 bg-[#00B2EC] transition-all duration-100"></div>
            </div>
        </div>

        <!-- Content Layer -->
        <div class="relative w-full max-w-6xl px-4 sm:px-8 z-10">

            <!-- ═══ Slide 0: Welcome ═══ -->
            <div class="story-slide opacity-0 absolute inset-0 flex flex-col items-center text-center justify-center translate-y-10 transition-all duration-700"
                data-index="0">
                <span class="text-[#00B2EC]  font-bold tracking-[0.2em] text-xs uppercase mb-4">Welcome to Daleel</span>
                <h1
                    class="font-['Poppins'] text-3xl sm:text-5xl md:text-7xl text-brand-navy dark:text-white font-extrabold leading-tight">
                    Global Vision.<br /><span class="text-gradient dark:text-white/70">Local Precision.</span>
                </h1>
                <p
                    class="mt-4 sm:mt-6 text-brand-navy/60 dark:text-white/70 text-base sm:text-lg max-w-2xl mx-auto leading-relaxed">
                    Navigate the complexities of international trade and information with the world's most advanced
                    intelligence platform.
                </p>
                <!-- Scroll Indicator -->
                <div class="mt-12 flex flex-col items-center gap-2 animate-bounce">
                    <span class="text-brand-navy/30 dark:text-white/30 text-xs uppercase tracking-widest">Scroll to
                        explore</span>
                    <span class="material-symbols-outlined text-brand-navy/30 dark:text-white/30">expand_more</span>
                </div>
            </div>

            <!-- ═══ Slide 1: Data Harvest ═══ -->
            <div class="story-slide opacity-0 absolute inset-0 flex items-center justify-center translate-y-10 transition-all duration-700 w-full"
                data-index="1">
                <div class="grid md:grid-cols-2 gap-4 sm:gap-8 md:gap-12 items-center w-full px-2 sm:px-0">
                    <!-- Start: Content -->
                    <div class="text-start">
                        <div
                            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#00B2EC]/10 text-[#00B2EC] dark:text-white/70 text-xs font-semibold tracking-wide mb-4 sm:mb-6">
                            <span class="material-symbols-outlined text-[14px]"
                                style="font-variation-settings: 'FILL' 1;">sensors</span>
                            Data Intelligence
                        </div>
                        <h2
                            class="font-['Poppins'] text-xl sm:text-3xl md:text-5xl dark:text-white/70 text-brand-navy font-bold leading-tight mb-3 sm:mb-6">
                            10M+ Sources.<br /><span class="text-brand-navy/50 dark:text-white/65">One Truth.</span>
                        </h2>
                        <p
                            class="text-brand-navy/60 dark:text-white/70 text-sm sm:text-lg leading-relaxed mb-6 sm:mb-8">
                            We harvest real-time data from 140 jurisdictions — news feeds, regulatory filings,
                            trade logs, and satellite imagery — turning raw information into strategic advantages.
                        </p>
                        <div class="grid grid-cols-3 gap-4 sm:gap-6 dark:text-white/70">
                            <div>
                                <p class="text-brand-navy dark:text-white font-bold text-2xl">140+</p>
                                <p class="text-brand-navy/40 dark:text-white/40 text-xs uppercase tracking-widest">
                                    Countries</p>
                            </div>
                            <div>
                                <p class="text-brand-navy dark:text-white font-bold text-2xl">24/7</p>
                                <p class="text-brand-navy/40 dark:text-white/40 text-xs uppercase tracking-widest">
                                    Monitoring</p>
                            </div>
                            <div>
                                <p class="text-brand-navy dark:text-white font-bold text-2xl">100%</p>
                                <p class="text-brand-navy/40 dark:text-white/40 text-xs uppercase tracking-widest">
                                    Verified</p>
                            </div>
                        </div>
                    </div>
                    <!-- Right: Visual -->
                    <div class="flex items-center justify-center mt-4 sm:mt-8 md:mt-0">
                        <div class="relative">
                            <img src="~/assets/images/globe_network.png" alt="Global intelligence network"
                                class="w-full max-w-[140px] sm:max-w-xs md:max-w-md rounded-2xl opacity-80 shadow-2xl shadow-[#00B2EC]/10" />
                            <div
                                class="absolute inset-0 rounded-2xl bg-gradient-to-t from-white/80 dark:from-brand-navy/60 to-transparent">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══ Slide 2: AI Engine ═══ -->
            <div class="story-slide opacity-0 absolute  inset-0 flex items-center justify-center translate-y-10 transition-all duration-700 w-full"
                data-index="2">
                <div class="grid md:grid-cols-2 gap-4 sm:gap-8 md:gap-12 items-center w-full px-2 sm:px-0">
                    <!-- Start: Visual -->
                    <div class="flex items-center justify-center order-2 md:order-none mt-4 sm:mt-8 md:mt-0">
                        <div class="relative">
                            <img src="~/assets/images/ai_neural.png" alt="AI neural fusion engine"
                                class="w-full max-w-[140px] sm:max-w-xs md:max-w-md rounded-2xl opacity-80 shadow-2xl shadow-[#EF4123]/10" />
                            <div
                                class="absolute inset-0 rounded-2xl bg-gradient-to-t from-white/80 dark:from-brand-navy/60 to-transparent">
                            </div>
                        </div>
                    </div>
                    <!-- Right: Content -->
                    <div class="text-start order-1">
                        <div
                            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#EF4123]/10 text-[#EF4123] text-xs font-semibold tracking-wide mb-4 sm:mb-6">
                            <span class="material-symbols-outlined text-[14px]"
                                style="font-variation-settings: 'FILL' 1;">psychology</span>
                            Neural Fusion Engine
                        </div>
                        <h2
                            class="font-['Poppins'] text-xl sm:text-3xl md:text-5xl text-brand-navy dark:text-white font-bold leading-tight mb-3 sm:mb-6">
                            AI That Sees<br /><span class="text-gradient-red">What You Can't.</span>
                        </h2>
                        <p
                            class="text-brand-navy/60 dark:text-white/70 text-sm sm:text-lg leading-relaxed mb-6 sm:mb-8">
                            Our proprietary Neural Fusion Engine cross-correlates geopolitical events with trade flows,
                            sentiment shifts, and macro indicators — uncovering hidden patterns invisible to the human
                            eye.
                        </p>
                        <!-- Mini progress bars -->
                        <div class="space-y-4 max-w-sm">
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-brand-navy/50 dark:text-white/65 text-xs">Pattern
                                        Recognition</span>
                                    <span class="text-[#EF4123] text-xs font-bold">94%</span>
                                </div>
                                <div
                                    class="w-full h-1.5 rounded-full bg-brand-navy/10 dark:bg-white/10 overflow-hidden">
                                    <div
                                        class="h-full rounded-full bg-gradient-to-r from-[#EF4123] to-[#F9A01B] w-[94%]">
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-brand-navy/50 dark:text-white/65 text-xs">Sentiment
                                        Analysis</span>
                                    <span class="text-[#F9A01B] text-xs font-bold">87%</span>
                                </div>
                                <div
                                    class="w-full h-1.5 rounded-full bg-brand-navy/10 dark:bg-white/10 overflow-hidden">
                                    <div
                                        class="h-full rounded-full bg-gradient-to-r from-[#F9A01B] to-[#00B2EC] w-[87%]">
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="text-brand-navy/50 dark:text-white/65 text-xs">Risk Correlation</span>
                                    <span class="text-[#00B2EC] text-xs font-bold">91%</span>
                                </div>
                                <div
                                    class="w-full h-1.5 rounded-full bg-brand-navy/10 dark:bg-white/10 overflow-hidden">
                                    <div class="h-full rounded-full bg-[#00B2EC] w-[91%]"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══ Slide 3: Strategic Dashboard ═══ -->
            <div class="story-slide opacity-0 absolute inset-0 flex items-center justify-center translate-y-10 transition-all duration-700 w-full"
                data-index="3">
                <div class="grid md:grid-cols-2 gap-4 sm:gap-8 md:gap-12 items-center w-full px-2 sm:px-0">
                    <!-- Start: Content -->
                    <div class="text-start">
                        <div
                            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#F9A01B]/10 text-[#F9A01B] text-xs font-semibold tracking-wide mb-4 sm:mb-6">
                            <span class="material-symbols-outlined text-[14px]"
                                style="font-variation-settings: 'FILL' 1;">dashboard</span>
                            Strategic Command
                        </div>
                        <h2
                            class="font-['Poppins'] text-xl sm:text-3xl md:text-5xl text-brand-navy dark:text-white font-bold leading-tight mb-3 sm:mb-6">
                            Clarity From<br /><span class="text-[#F9A01B]">Complexity.</span>
                        </h2>
                        <p
                            class="text-brand-navy/60 dark:text-white/70 text-sm sm:text-lg leading-relaxed mb-6 sm:mb-8">
                            Our analysts distill fused intelligence into actionable strategic briefs — complete with
                            scenario modeling, risk heat maps, and opportunity scoring — delivered in real time.
                        </p>
                        <!-- Mini dashboard stats -->
                        <div class="grid grid-cols-2 gap-4 max-w-sm">
                            <div class="glass-card rounded-xl p-4 text-center">
                                <p class="font-['Poppins'] text-2xl font-bold text-emerald-400">▲ 12.4%</p>
                                <p
                                    class="text-brand-navy/40 dark:text-white/40 text-[10px] uppercase tracking-wider mt-1">
                                    Opportunity Score</p>
                            </div>
                            <div class="glass-card rounded-xl p-4 text-center">
                                <p class="font-['Poppins'] text-2xl font-bold text-[#EF4123]">▼ 3.1%</p>
                                <p
                                    class="text-brand-navy/40 dark:text-white/40 text-[10px] uppercase tracking-wider mt-1">
                                    Risk Exposure</p>
                            </div>
                        </div>
                    </div>
                    <!-- Right: Visual -->
                    <div class="flex items-center justify-center mt-4 sm:mt-8 md:mt-0">
                        <div class="relative">
                            <img src="~/assets/images/data_dashboard.png" alt="Strategic analytics dashboard"
                                class="w-full max-w-[160px] sm:max-w-xs md:max-w-md rounded-2xl opacity-80 shadow-2xl shadow-[#F9A01B]/10" />
                            <div
                                class="absolute inset-0 rounded-2xl bg-gradient-to-t from-white/80 dark:from-brand-navy/60 to-transparent">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══ Slide 4: CTA ═══ -->
            <div class="story-slide opacity-0 absolute inset-0 flex flex-col items-center text-center justify-center translate-y-10 transition-all duration-700 px-2 sm:px-0 w-full"
                data-index="4">
                <div
                    class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl glass-card flex items-center justify-center mb-6 sm:mb-8">
                    <span class="material-symbols-outlined text-[#00B2EC] text-3xl sm:text-4xl"
                        style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
                </div>
                <h2
                    class="font-['Poppins'] text-2xl sm:text-4xl md:text-6xl text-brand-navy dark:text-white font-bold mb-3 sm:mb-4">
                    Ready to Lead?</h2>
                <p class="text-brand-navy/50 dark:text-white/65 text-sm sm:text-lg max-w-xl mb-6 sm:mb-10 px-4">
                    Join 150,000+ trade partners across 140 jurisdictions who trust Daleel to power their global
                    strategy.
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <button
                        class="relative group overflow-hidden bg-gradient-to-r from-[#00B2EC] to-[#008dbb] text-white px-8 py-3 rounded-2xl font-semibold transition-all hover:scale-[1.02] active:scale-95 shadow-lg shadow-blue-500/25">
                        <span class="relative z-10">Explore Solutions</span>
                        <div
                            class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                        </div>
                    </button>

                    <button
                        class="backdrop-blur-md bg-brand-navy/5 dark:bg-white/5 border border-brand-navy/10 dark:border-white/10 text-brand-navy dark:text-white px-8 py-3 rounded-2xl font-semibold transition-all hover:bg-brand-navy/10 dark:hover:bg-white/10 active:scale-95">
                        Download Briefing
                    </button>
                </div>
            </div>

        </div><!-- /content layer -->
    </div><!-- /sticky -->
</section>

<section class="relative bg-[#F8F9FA] dark:bg-[#060D1A] overflow-hidden py-20 sm:py-28 transition-colors duration-300">

    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div
            class="absolute -top-32 ltr:-right-32 rtl:-left-32 w-[600px] h-[600px] rounded-full bg-[#00B2EC]/5 blur-3xl">
        </div>
        <div
            class="absolute -bottom-40 ltr:-left-40 rtl:-right-40 w-[500px] h-[500px] rounded-full bg-[#F9A01B]/5 blur-3xl">
        </div>
    </div>

    <div class="relative z-10 max-w-[1440px] mx-auto px-6 sm:px-8 grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="space-y-8 text-start" data-animate="slide-start">
            <div
                class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gradient-to-r from-[#00B2EC] to-[#008dbb] text-white font-['Inter'] text-xs font-semibold tracking-wide shadow-sm">
                <span class="material-symbols-outlined text-[14px]"
                    style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                Enterprise Grade Intelligence
            </div>

            <h1
                class="font-['Poppins'] text-[clamp(2.25rem,5vw,3.5rem)] font-extrabold leading-[1.1] tracking-tight text-brand-navy dark:text-white transition-colors duration-300">
                Precision Strategy<br class="hidden lg:block" /> for the Global&nbsp;Market.
            </h1>

            <p
                class="font-['Inter'] text-lg leading-relaxed text-slate-500 dark:text-slate-400 max-w-xl transition-colors duration-300">
                Daleel Global Vision provides the navigational clarity required to dominate complex international
                landscapes through data-driven precision.
            </p>

            <div class="flex flex-wrap gap-4 pt-2">
                <button
                    class="bg-[#00B2EC] text-white px-8 py-4 rounded-xl font-['Inter'] font-semibold text-base shadow-lg shadow-[#00B2EC]/20 hover:shadow-xl hover:shadow-[#00B2EC]/30 active:scale-95 transition-all duration-300">
                    Explore Solutions
                </button>
                <button
                    class="border border-brand-navy/20 dark:border-white/20 text-brand-navy dark:text-white px-8 py-4 rounded-xl font-['Inter'] font-semibold text-base hover:bg-brand-navy/5 dark:hover:bg-white/5 active:scale-95 transition-all duration-300">
                    Watch Briefing
                </button>
            </div>
        </div>

        <div class="bg-white/70 dark:bg-[#0A192F]/70 backdrop-blur-xl border border-slate-200 dark:border-slate-800 shadow-lg rounded-2xl p-6 sm:p-8 transition-all duration-300"
            data-animate="slide-end" data-delay="2">
            <div class="space-y-6">
                <div class="flex items-center justify-between">
                    <h3
                        class="font-['Poppins'] text-xl font-semibold text-brand-navy dark:text-white flex items-center gap-2.5">
                        <span class="material-symbols-outlined text-[#00B2EC]"
                            style="font-variation-settings: 'FILL' 1;">psychology</span>
                        Global Insight AI
                    </h3>
                    <span class="inline-flex items-center gap-2 text-xs font-['Inter'] font-medium text-slate-400">
                        <span class="relative flex h-2.5 w-2.5">
                            <span
                                class="absolute inline-flex h-full w-full rounded-full bg-[#00B2EC] opacity-75 animate-ping"></span>
                            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-[#00B2EC]"></span>
                        </span>
