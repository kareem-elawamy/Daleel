                            class="text-brand-navy/40 dark:text-brand-navy dark:text-white/30 text-xs font-['Inter']">@SharedLocalizer["JurisdictionsCovered"]</span>
                    </div>
                </div>
            </div>

            <!-- Card 5: Predictive, Not Reactive -->
            <div class="group glass-card rounded-2xl p-8 hover:border-[#10B981]/30 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(239,65,35,0.1)] transition-all duration-500 text-start"
                data-animate="scale-in" data-delay="5">
                <div
                    class="w-14 h-14 rounded-xl bg-[#10B981]/10 flex items-center justify-center mb-6 group-hover:bg-[#10B981]/20 group-hover:scale-110 group-hover:shadow-[0_0_15px_rgba(239,65,35,0.2)] transition-all duration-500">
                    <span class="material-symbols-outlined text-[#10B981] text-[28px]"
                        style="font-variation-settings: 'FILL' 1;">trending_up</span>
                </div>
                <h3 class="font-['Poppins'] text-xl font-bold text-brand-navy dark:text-white mb-3">@SharedLocalizer["PredictiveNotReactive"]</h3>
                <p
                    class="font-['Inter'] text-brand-navy/60 dark:text-brand-navy/10 dark:text-brand-navy dark:text-white/50 leading-relaxed text-sm">
                    @SharedLocalizer["PredictiveDesc"]
                </p>
                <div class="mt-6 pt-6 border-t border-brand-navy/10 dark:border-white/5">
                    <div class="flex items-center gap-3">
                        <span class="text-[#10B981] font-['Poppins'] text-2xl font-bold" dir="auto">@ToLocalNumerals("24/7")</span>
                        <span
                            class="text-brand-navy/40 dark:text-brand-navy dark:text-white/30 text-xs font-['Inter']">@SharedLocalizer["EarlyWarningAdvantage"]</span>
                    </div>
                </div>
            </div>

            <!-- Card 6: Enterprise-Grade Security -->
            <div class="group glass-card rounded-2xl p-8 hover:border-[#F9A01B]/30 hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(249,160,27,0.1)] transition-all duration-500 text-start"
                data-animate="scale-in" data-delay="6">
                <div
                    class="w-14 h-14 rounded-xl bg-[#F9A01B]/10 flex items-center justify-center mb-6 group-hover:bg-[#F9A01B]/20 group-hover:scale-110 group-hover:shadow-[0_0_15px_rgba(249,160,27,0.2)] transition-all duration-500">
                    <span class="material-symbols-outlined text-[#F9A01B] text-[28px]"
                        style="font-variation-settings: 'FILL' 1;">shield_lock</span>
                </div>
                <h3 class="font-['Poppins'] text-xl font-bold text-brand-navy dark:text-white mb-3">@SharedLocalizer["EnterpriseSecurity"]</h3>
                <p
                    class="font-['Inter'] text-brand-navy/60 dark:text-brand-navy/10 dark:text-brand-navy dark:text-white/50 leading-relaxed text-sm">
                    @SharedLocalizer["EnterpriseSecurityDesc"]
                </p>
                <div class="mt-6 pt-6 border-t border-brand-navy/10 dark:border-white/5">
                    <div class="flex items-center gap-3">
                        <span class="text-[#F9A01B] font-['Poppins'] text-2xl font-bold" dir="auto">@ToLocalNumerals("SOC 2")</span>
                        <span
                            class="text-brand-navy/40 dark:text-brand-navy dark:text-white/30 text-xs font-['Inter']">@SharedLocalizer["CertifiedEncrypted"]</span>
                    </div>
                </div>
            </div>

        </div>

        <!-- Bottom CTA -->
        <div class="text-center mt-16 sm:mt-24 pb-10" data-animate="fade-up" data-delay="7">
            <div class="w-24 h-1 bg-[#00B2EC]/20 mx-auto mb-8 rounded-full"></div>

            <p
                class="font-['Inter'] text-slate-500 dark:text-slate-400 text-sm font-medium tracking-wide mb-6 uppercase">
                @SharedLocalizer["ReadyToExperience"]
            </p>

            <a asp-controller="Home" asp-action="ScheduleDemo"
                class="group relative inline-flex items-center gap-3 bg-[#00B2EC] text-white px-10 py-4 rounded-2xl font-['Inter'] font-bold text-lg shadow-[0_10px_30px_rgba(0,178,236,0.3)] hover:shadow-[0_15px_40px_rgba(0,178,236,0.5)] hover:-translate-y-1 active:scale-95 transition-all duration-300">

                <span
                    class="absolute inset-0 rounded-2xl bg-[#00B2EC] blur-md opacity-0 group-hover:opacity-40 transition-opacity"></span>

                <span class="relative z-10">@SharedLocalizer["ScheduleDemo"]</span>

                <span
                    class="relative z-10 material-symbols-outlined text-[22px] transition-transform duration-300 group-hover:translate-x-1.5 rtl:group-hover:-translate-x-1.5 rtl:rotate-180">
                    arrow_forward
                </span>
            </a>

            <div class="mt-6">
                <a asp-controller="Home" asp-action="Pricing"
                    class="text-slate-400 hover:text-[#00B2EC] text-xs font-semibold transition-colors border-b border-transparent hover:border-[#00B2EC] pb-0.5">
                    @SharedLocalizer["ViewPricingPlans"]
                </a>
            </div>
        </div>

    </div>
</section>



<!-- @SharedLocalizer["GlobalPerspectives"] / Insights -->
<section class="relative bg-[#F8F9FA] dark:bg-[#060D1A] py-24 sm:py-32 overflow-hidden transition-colors duration-300">

    <!-- Background Decoration -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute -top-20 ltr:right-0 rtl:left-0 w-[500px] h-[500px] rounded-full bg-[#00B2EC]/[0.03] blur-[100px]"></div>
    </div>

    <div class="relative z-10 max-w-[1440px] mx-auto px-6 sm:px-8">

        <!-- Section Header -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6 mb-12 sm:mb-16">
            <div class="text-start" data-animate="fade-up">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-navy/5 dark:bg-white/5 text-brand-navy dark:text-slate-300 font-['Inter'] text-xs font-semibold tracking-wide mb-6">
                    <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">insights</span>
                    @SharedLocalizer["IntelligenceFeed"]
                </div>
                <h2 class="font-['Poppins'] text-3xl sm:text-4xl font-bold text-brand-navy dark:text-white mb-2">@SharedLocalizer["GlobalPerspectives"]</h2>
                <p class="font-['Inter'] text-slate-500 dark:text-slate-400 text-base sm:text-lg">@SharedLocalizer["StrategicInsightsDesc"]</p>
            </div>
            <a asp-action="soon"
                class="inline-flex items-center gap-2 text-[#00B2EC] font-['Inter'] font-semibold text-sm hover:gap-3 transition-all duration-300 shrink-0 group">
                @SharedLocalizer["ViewAllInsights"]
                <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 rtl:group-hover:-translate-x-0.5 rtl:rotate-180 transition-transform">arrow_forward</span>
            </a>
        </div>

        <!-- Bento Grid -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[280px] sm:auto-rows-[300px]">

            <!-- Main Feature (Large) -->
