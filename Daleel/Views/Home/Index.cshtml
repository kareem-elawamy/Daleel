                    </div>
                </div>
            </a>

            <!-- Secondary Card 2 -->
            <a asp-controller="Home" asp-action="Article" class="block md:col-span-5 relative rounded-2xl overflow-hidden group cursor-pointer bg-white dark:bg-[#0A192F] shadow-sm hover:shadow-xl transition-all duration-500" data-animate="slide-end" data-delay="3">
                <div class="h-full p-8 flex flex-col justify-between text-start">
                    <div>
                        <div class="flex items-center gap-2 mb-4">
                            <span class="bg-[#F9A01B]/10 text-[#F9A01B] px-2.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">@SharedLocalizer["Analysis"]</span>
                            <span class="text-slate-300 dark:text-slate-500 text-xs font-['Inter']" dir="auto">@ToLocalNumerals(SharedLocalizer["May082024"].Value)</span>
                        </div>
                        <h4 class="font-['Poppins'] text-lg sm:text-xl font-bold text-brand-navy dark:text-white mb-3 group-hover:text-[#00B2EC] transition-colors duration-300" dir="auto">
                            @ToLocalNumerals(SharedLocalizer["AnalysisTitle"].Value)
                        </h4>
                        <p class="font-['Inter'] text-slate-400 text-sm leading-relaxed line-clamp-3" dir="auto">
                            @ToLocalNumerals(SharedLocalizer["AnalysisDesc"].Value)
                        </p>
                    </div>
                    <div class="flex items-center justify-between mt-6 pt-4 border-t border-slate-100 dark:border-slate-800">
                        <span class="text-slate-400 text-xs font-['Inter']" dir="auto">@ToLocalNumerals(SharedLocalizer["MinRead6"].Value)</span>
                        <span class="material-symbols-outlined text-slate-300 dark:text-slate-500 group-hover:text-[#00B2EC] transition-colors text-[20px] rtl:-scale-x-100">north_east</span>
                    </div>
                </div>
            </a>

        </div>

        <!-- Bottom Row: Quick Articles -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-6">
            <a asp-controller="Home" asp-action="Article" class="block group bg-white dark:bg-[#0A192F] rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 cursor-pointer text-start" data-animate="fade-up" data-delay="4">
                <div class="flex items-center gap-2 mb-3">
                    <span class="w-2 h-2 rounded-full bg-[#00B2EC]"></span>
                    <span class="text-slate-400 text-[10px] font-['Inter'] uppercase tracking-wider">@SharedLocalizer["TradeAlert"]</span>
                </div>
                <h5 class="font-['Poppins'] text-sm font-bold text-brand-navy dark:text-white group-hover:text-[#00B2EC] transition-colors leading-snug">
                    @ToLocalNumerals(SharedLocalizer["TradeAlertTitle"].Value)
                </h5>
            </a>
            <a asp-controller="Home" asp-action="Article" class="block group bg-white dark:bg-[#0A192F] rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 cursor-pointer text-start" data-animate="fade-up" data-delay="5">
                <div class="flex items-center gap-2 mb-3">
                    <span class="w-2 h-2 rounded-full bg-[#10B981]"></span>
                    <span class="text-slate-400 text-[10px] font-['Inter'] uppercase tracking-wider">@SharedLocalizer["RiskAlert"]</span>
                </div>
                <h5 class="font-['Poppins'] text-sm font-bold text-brand-navy dark:text-white group-hover:text-[#00B2EC] transition-colors leading-snug">
                    @ToLocalNumerals(SharedLocalizer["RiskAlertTitle"].Value)
                </h5>
            </a>
            <a asp-controller="Home" asp-action="Article" class="block group bg-white dark:bg-[#0A192F] rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 cursor-pointer text-start" data-animate="fade-up" data-delay="6">
                <div class="flex items-center gap-2 mb-3">
                    <span class="w-2 h-2 rounded-full bg-[#F9A01B]"></span>
                    <span class="text-slate-400 text-[10px] font-['Inter'] uppercase tracking-wider">@SharedLocalizer["MediaWatch"]</span>
                </div>
                <h5 class="font-['Poppins'] text-sm font-bold text-brand-navy dark:text-white group-hover:text-[#00B2EC] transition-colors leading-snug">
                    @ToLocalNumerals(SharedLocalizer["MediaWatchTitle"].Value)
                </h5>
            </a>
            <a asp-controller="Home" asp-action="Article" class="block group bg-white dark:bg-[#0A192F] rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 cursor-pointer text-start" data-animate="fade-up" data-delay="7">
                <div class="flex items-center gap-2 mb-3">
                    <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
                    <span class="text-slate-400 text-[10px] font-['Inter'] uppercase tracking-wider">@SharedLocalizer["Opportunity"]</span>
                </div>
                <h5 class="font-['Poppins'] text-sm font-bold text-brand-navy dark:text-white group-hover:text-[#00B2EC] transition-colors leading-snug">
                    @ToLocalNumerals(SharedLocalizer["OpportunityTitle"].Value)
                </h5>
            </a>
        </div>

    </div>
</section>

