                </div>
            </div>

            <div
                class="relative overflow-hidden bg-white/70 dark:bg-[#0A192F]/70 backdrop-blur-xl border border-slate-200 dark:border-slate-800 shadow-lg rounded-2xl p-6 text-center group hover:-translate-y-2 transition-all duration-300">
                <div
                    class="absolute inset-0 bg-gradient-to-tr from-transparent via-[#00B2EC]/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000">
                </div>
                <div class="relative z-10">
                    <p
                        class="font-['Poppins'] text-2xl sm:text-3xl font-bold text-[#00B2EC] group-hover:scale-110 transition-transform duration-300">
                        100%</p>
                    <p class="font-['Inter'] text-xs font-medium text-slate-400 uppercase tracking-widest mt-1.5">Trust
