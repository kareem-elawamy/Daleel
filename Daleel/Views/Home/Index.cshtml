                <div
                    class="absolute inset-0 bg-gradient-to-tr from-transparent via-[#00B2EC]/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000">
                </div>
                <div class="relative z-10">
                    <p
                        class="font-['Poppins'] text-2xl sm:text-3xl font-bold text-[#00B2EC] group-hover:scale-110 transition-transform duration-300">
