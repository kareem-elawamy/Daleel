                    </span>
                </div>

                <div class="relative">
                    <input
                        class="w-full bg-white dark:bg-[#112240] p-4 pe-14 rounded-xl border border-slate-200 dark:border-slate-700 focus:ring-2 focus:ring-[#00B2EC] outline-none text-brand-navy dark:text-white"
                        placeholder="Analyze trade corridors..." type="text" />
                    <button
                        class="absolute end-3 top-1/2 -translate-y-1/2 p-2 bg-[#00B2EC] text-white rounded-lg hover:bg-[#00a0d6] transition-all">
                        <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                    </button>
                </div>

                <div class="flex flex-wrap gap-2">
                    <button
                        class="px-3.5 py-1.5 rounded-full text-xs bg-slate-100 dark:bg-[#112240] text-slate-600 dark:text-slate-300 hover:bg-[#00B2EC] hover:text-white transition-all">Market
                        Volatility</button>
                    <button
                        class="px-3.5 py-1.5 rounded-full text-xs bg-slate-100 dark:bg-[#112240] text-slate-600 dark:text-slate-300 hover:bg-[#00B2EC] hover:text-white transition-all">Supply
                        Chain</button>
                </div>
            </div>
        </div>
