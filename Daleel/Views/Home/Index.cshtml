        </div>
    </div>
</section>

<!-- The Daleel Framework -->
<section class="relative py-24 sm:py-32 bg-white dark:bg-[#060D1A] overflow-hidden transition-colors duration-300">

    <!-- Subtle Background Pattern -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute top-20 ltr:-left-20 rtl:-right-20 w-[500px] h-[500px] rounded-full bg-[#00B2EC]/[0.04] blur-[100px] animate-pulse-slow"></div>
        <div class="absolute bottom-20 ltr:-right-20 rtl:-left-20 w-[400px] h-[400px] rounded-full bg-[#F9A01B]/[0.03] blur-[80px] animate-pulse-slow" style="animation-delay: 1.5s;"></div>
    </div>

    <div class="relative z-10 max-w-[1440px] mx-auto px-6 sm:px-8">

        <!-- Section Header -->
