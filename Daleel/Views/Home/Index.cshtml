                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

                <!-- Badge + Content -->
                <div class="absolute bottom-0 start-0 p-8 sm:p-10 text-start">
                    <span class="bg-[#00B2EC] text-white px-3 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider mb-4 inline-block shadow-lg shadow-[#00B2EC]/20">
                        @SharedLocalizer["WhitePaper"]
                    </span>
                    <h3 class="font-['Poppins'] text-xl sm:text-2xl font-bold text-white mb-3 leading-snug max-w-lg" dir="auto">
                        @ToLocalNumerals(SharedLocalizer["WhitePaperTitle"].Value)
                    </h3>
                    <p class="font-['Inter'] text-white/70 text-sm max-w-md leading-relaxed" dir="auto">
                        @ToLocalNumerals(SharedLocalizer["WhitePaperDesc"].Value)
                    </p>
                    <div class="mt-5 flex items-center gap-4">
                        <span class="text-white/40 text-xs font-['Inter']" dir="auto">@ToLocalNumerals(SharedLocalizer["MinRead12"].Value)</span>
                        <span class="w-1 h-1 rounded-full bg-white/20"></span>
                        <span class="text-white/40 text-xs font-['Inter']" dir="auto">@ToLocalNumerals(SharedLocalizer["May152024"].Value)</span>
                    </div>
                </div>

                <!-- Hover Arrow -->
                <div class="absolute top-6 end-6 w-10 h-10 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
                    <span class="material-symbols-outlined text-white text-[20px] rtl:-scale-x-100">north_east</span>
                </div>
            </a>

            <!-- Secondary Card 1 -->
            <a asp-controller="Home" asp-action="Article" class="block md:col-span-5 relative rounded-2xl overflow-hidden group cursor-pointer bg-white dark:bg-[#0A192F] shadow-sm hover:shadow-xl transition-all duration-500" data-animate="slide-end" data-delay="2">
                <div class="h-full p-8 flex flex-col justify-between text-start">
                    <div>
                        <div class="flex items-center gap-2 mb-4">
                            <span class="bg-[#10B981]/10 text-[#10B981] px-2.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">@SharedLocalizer["Report"]</span>
                            <span class="text-slate-300 dark:text-slate-500 text-xs font-['Inter']" dir="auto">@ToLocalNumerals(SharedLocalizer["May122024"].Value)</span>
                        </div>
                        <h4 class="font-['Poppins'] text-lg sm:text-xl font-bold text-brand-navy dark:text-white mb-3 group-hover:text-[#00B2EC] transition-colors duration-300" dir="auto">
                            @ToLocalNumerals(SharedLocalizer["ReportTitle"].Value)
