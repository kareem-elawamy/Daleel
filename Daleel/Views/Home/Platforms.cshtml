                </div>
                <button class="platform-tab active-tab relative z-10 px-8 sm:px-10 py-3 font-['Poppins'] font-semibold text-sm sm:text-base text-[#00B2EC] transition-colors duration-300 rounded-full" data-target="tab-info">
                    @SharedLocalizer["TabInformation"]
                </button>
                <button class="platform-tab relative z-10 px-8 sm:px-10 py-3 font-['Poppins'] font-semibold text-sm sm:text-base text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300 transition-colors duration-300 rounded-full" data-target="tab-trade">
                    @SharedLocalizer["TabTrade"]
