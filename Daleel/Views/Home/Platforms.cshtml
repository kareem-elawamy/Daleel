                                    <span class="material-symbols-outlined text-[#F9A01B] text-[14px]">check</span>
                                </span>
                                @SharedLocalizer["MediaFeature2"]
                            </li>
                            <li class="flex items-center gap-3">
                                <span class="w-6 h-6 rounded-full bg-[#F9A01B]/20 flex items-center justify-center shrink-0">
                                    <span class="material-symbols-outlined text-[#F9A01B] text-[14px]">check</span>
                                </span>
                                @SharedLocalizer["MediaFeature3"]
                            </li>
                        </ul>
                        <a href="#" class="inline-flex items-center gap-2 text-[#F9A01B] font-['Inter'] font-semibold mt-4 hover:gap-3 transition-all duration-300 group">
                            @SharedLocalizer["ExploreMediaPlatform"]
