                            @SharedLocalizer["TradePlatformTitle"]
                        </h3>
                        <p class="font-['Inter'] text-slate-900 dark:text-white text-lg leading-relaxed">
                            @SharedLocalizer["TradePlatformDesc"]
                        </p>
                        <ul class="space-y-4 font-['Inter'] text-slate-900 dark:text-slate-200 font-medium">
                            <li class="flex items-center gap-3">
                                <span class="w-6 h-6 rounded-full bg-[#10B981]/20 flex items-center justify-center shrink-0">
                                    <span class="material-symbols-outlined text-[#10B981] text-[14px]">check</span>
                                </span>
                                @SharedLocalizer["TradeFeature1"]
                            </li>
                            <li class="flex items-center gap-3">
                                <span class="w-6 h-6 rounded-full bg-[#10B981]/20 flex items-center justify-center shrink-0">
                                    <span class="material-symbols-outlined text-[#10B981] text-[14px]">check</span>
                                </span>
