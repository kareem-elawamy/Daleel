                <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
                    <div class="relative group">
                        <div class="absolute inset-0 bg-gradient-to-tl from-[#10B981]/20 to-transparent rounded-[2rem] transform ltr:-translate-x-4 ltr:translate-y-4 rtl:translate-x-4 rtl:translate-y-4 group-hover:translate-y-6 transition-transform duration-700"></div>
