            <div id="platform-tabs-container"
                class="relative inline-flex items-center bg-[#F8F9FA] dark:bg-[#0A192F] border border-slate-200 dark:border-slate-800 rounded-full p-1.5 shadow-sm">
                <div id="platform-tab-indicator"
