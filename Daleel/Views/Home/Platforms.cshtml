            <h2 class="font-['Poppins'] text-3xl sm:text-4xl md:text-5xl font-bold text-slate-900 dark:text-white leading-tight mb-6">
                @SharedLocalizer["PlatformsHeading"]
            </h2>
            <p class="font-['Inter'] text-base sm:text-lg text-slate-900 dark:text-white leading-relaxed">
                @SharedLocalizer["PlatformsDesc"]
            </p>
        </div>

        <!-- Dynamic Tabs Navigation -->
