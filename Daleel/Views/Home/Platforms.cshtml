@{
    ViewData["Title"] = "Platforms";
}

@functions {
    public string ToLocalNumerals(string input)
    {
        if (System.Threading.Thread.CurrentThread.CurrentCulture.Name.StartsWith("ar"))
        {
            string replaced = input.Replace("M", " مليون")
                                   .Replace("K", " ألف")
                                   .Replace("min", " دقائق")
                                   .Replace("-in-", " في ")
                                   .Replace('0', '٠')
                                   .Replace('1', '١')
                                   .Replace('2', '٢')
                                   .Replace('3', '٣')
                                   .Replace('4', '٤')
                                   .Replace('5', '٥')
                                   .Replace('6', '٦')
                                   .Replace('7', '٧')
                                   .Replace('8', '٨')
                                   .Replace('9', '٩');
                                   
            if (replaced.EndsWith("+"))
            {
                replaced = "+" + replaced.TrimEnd('+');
            }
            
            return replaced;
        }
        return input;
    }
}

<section class="relative bg-white dark:bg-[#0A192F] py-24 sm:py-32 overflow-hidden transition-colors duration-300">

    <!-- Ambient Background Glows -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute top-1/4 ltr:-right-40 rtl:-left-40 w-[600px] h-[600px] rounded-full bg-[#00B2EC]/5 blur-[120px]"></div>
        <div class="absolute bottom-0 ltr:-left-20 rtl:-right-20 w-[500px] h-[500px] rounded-full bg-[#10B981]/5 blur-[100px]"></div>
    </div>

    <div class="relative z-10 max-w-[1440px] mx-auto px-6 sm:px-8">

        <!-- Section Header -->
        <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16" data-animate="fade-up">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gradient-to-r from-[#00B2EC]/10 via-[#10B981]/10 to-[#fdc70c]/10 border border-slate-200 dark:border-slate-800 text-slate-900 dark:text-slate-300 font-['Inter'] text-xs font-semibold tracking-wide mb-6">
